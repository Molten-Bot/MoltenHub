# Local server settings
MOLTENHUB_ADDR=:8080
HUMAN_AUTH_PROVIDER=dev
MOLTENHUB_UI_DEV_MODE=true
MOLTENHUB_ENABLE_LOCAL_CORS=false
# Comma-separated browser origins allowed to call API routes cross-origin.
# Supports full origins (https://app.molten.bot) or host shorthand (app.molten.bot => allows both http+https for that host).
# MOLTENHUB_CORS_ALLOWED_ORIGINS=app.molten.bot,app.molten-qa.site
MOLTENHUB_HEADLESS_MODE=false
# When headless mode is enabled, redirect non-API UI/page requests here instead of returning 404.
# MOLTENHUB_HEADLESS_MODE_URL=https://example.com
MOLTENHUB_CANONICAL_BASE_URL=http://localhost:8080

# Local dev login identity (used by / login page in dev auth mode)
DEV_LOGIN_HUMAN_ID=your-name
DEV_LOGIN_HUMAN_EMAIL=you-name@example.com
DEV_LOGIN_AUTO=true

# Super-admin identities.
SUPER_ADMIN_REVIEW_MODE=true
SUPER_ADMIN_EMAILS=your-name@example.com
SUPER_ADMIN_DOMAINS=example.com

# Optional
BIND_TOKEN_TTL_MINUTES=15
# Optional shared key for /v1/entities/metadata.
# Set this explicitly to a random value if you need the endpoint.
# MOLTENHUB_ENTITIES_METADATA_KEY=<set-random-shared-key>
# Metadata payload max bytes across human/org/agent metadata write endpoints (default 196608 = 192KB)
# MOLTENHUB_MAX_METADATA_BYTES=196608
MOLTENHUB_STATE_BACKEND=memory
MOLTENHUB_QUEUE_BACKEND=memory
# strict (default) or degraded (fallback to memory while exposing dependency errors in /health)
MOLTENHUB_STORAGE_STARTUP_MODE=strict

# S3 state backend (set MOLTENHUB_STATE_BACKEND=s3)
# MOLTENHUB_STATE_S3_ENDPOINT=http://localhost:9000
# MOLTENHUB_STATE_S3_BUCKET=moltenhub-state
# MOLTENHUB_STATE_S3_REGION=us-east-1
# MOLTENHUB_STATE_S3_PREFIX=moltenhub-state
# MOLTENHUB_STATE_S3_PATH_STYLE=true
# MOLTENHUB_STATE_S3_ACCESS_KEY_ID=...
# MOLTENHUB_STATE_S3_SECRET_ACCESS_KEY=...

# S3 queue backend (set MOLTENHUB_QUEUE_BACKEND=s3)
# MOLTENHUB_QUEUE_S3_ENDPOINT=http://localhost:9000
# MOLTENHUB_QUEUE_S3_BUCKET=moltenhub-queue
# MOLTENHUB_QUEUE_S3_REGION=us-east-1
# MOLTENHUB_QUEUE_S3_PREFIX=moltenhub-queue
# MOLTENHUB_QUEUE_S3_PATH_STYLE=true
# MOLTENHUB_QUEUE_S3_ACCESS_KEY_ID=...
# MOLTENHUB_QUEUE_S3_SECRET_ACCESS_KEY=...
